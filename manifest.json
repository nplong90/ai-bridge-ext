{
  "manifest_version": 3,
  "key": "",
  "name": "AI Bridge (dev)",
  "version": "0.2.0",
  "description": "Bridge to ChatGPT/Gemini via the logged-in web session; pluggable providers.",
  "permissions": ["scripting", "tabs", "storage", "sidePanel", "nativeMessaging", "alarms"],
  "host_permissions": ["https://chatgpt.com/*", "https://gemini.google.com/*", "https://*.googleusercontent.com/*", "https://*.usercontent.google.com/*", "https://lh3.google.com/*", "https://*.oaiusercontent.com/*", "https://push.clients6.google.com/*"],
  "background": { "service_worker": "src/background.js", "type": "module" },
  "action": { "default_title": "AI Bridge" },
  "side_panel": { "default_path": "src/sidepanel.html" },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://gemini.google.com/*"],
      "js": ["src/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://chatgpt.com/*", "https://gemini.google.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/shared.js", "src/parsers.js", "src/drivers/index.js", "src/drivers/chatgpt.js", "src/drivers/gemini.js"],
      "matches": ["https://chatgpt.com/*", "https://gemini.google.com/*"]
    }
  ]
}
